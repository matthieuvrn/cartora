generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum PlanStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED

  @@map("plan_status")
}

enum PlanTier {
  FREE
  STARTER
  PRO

  @@map("plan_tier")
}

enum MenuStatus {
  DRAFT
  PUBLISHED

  @@map("menu_status")
}

enum MenuTemplate {
  CLASSIC
  CARTORA
  BISTRO
  NOIR
  SOLAR
  ZEN
  NEON
  RIVAGE
  VELOURS

  @@map("menu_template")
}

enum ItemBadge {
  NONE
  NEW
  POPULAR

  @@map("item_badge")
}

enum Allergen {
  GLUTEN
  CRUSTACEANS
  EGGS
  FISH
  PEANUTS
  SOYBEANS
  MILK
  NUTS
  CELERY
  MUSTARD
  SESAME
  SULPHITES
  LUPIN
  MOLLUSCS

  @@map("allergen")
}

/// ⚠️ Réservé aux tables ANALYTICS (menu_view_events, menu_view_daily_stats,
/// landing_events) — chrome visiteur fr/en. Les locales du CONTENU des menus
/// vivent en TEXT sur `translations.locale` (codes ISO minuscules, cf. S4).
enum Locale {
  FR
  EN

  @@map("locale")
}

enum DeviceType {
  MOBILE
  DESKTOP
  TABLET

  @@map("device_type")
}

enum ViewSource {
  QR
  DIRECT
  LINK

  @@map("view_source")
}

enum RestaurantType {
  TRADITIONAL
  PIZZERIA
  BRASSERIE
  BAR
  CAFE
  CREPERIE
  FASTFOOD
  BAKERY

  @@map("restaurant_type")
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Restaurant {
  id                    String          @id @default(uuid()) @db.Uuid
  ownerUserId           String          @unique @map("owner_user_id") @db.Uuid
  displayName           String          @map("display_name")
  slug                  String          @unique
  planStatus            PlanStatus      @default(FREE) @map("plan_status")
  planTier              PlanTier        @default(FREE) @map("plan_tier")
  restaurantType        RestaurantType? @map("restaurant_type")
  logoPath              String?         @map("logo_path")
  brandPrimary          String?         @map("brand_primary") @db.VarChar(7)
  brandAccent           String?         @map("brand_accent") @db.VarChar(7)
  brandBackground       String?         @map("brand_background") @db.VarChar(7)
  /// Langue de saisie du restaurateur (S4). CHECK SQL: fr|en|es|de|it.
  sourceLocale          String          @default("fr") @map("source_locale")
  /// Langues cibles activées (S4). CHECK SQL: sous-ensemble de fr|en|es|de|it.
  menuLocales           String[]        @default([]) @map("menu_locales")
  /// Personnalisation du QR (page Partage), découplée du template. NULL = look par défaut.
  /// Forme validée par QrStylePolicy (l'app est le seul writer) — pas de CHECK DB.
  qrStyle               Json?           @map("qr_style")
  activationDismissedAt DateTime?       @map("activation_dismissed_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  menu         Menu?
  billing      Billing?
  categories   Category[]
  items        Item[]
  translations Translation[]
  snapshots          MenuPublicSnapshot[]
  menuViewEvents     MenuViewEvent[]
  menuViewDailyStats MenuViewDailyStat[]
  dailyDishes   DailyDish[]
  formulas           Formula[]

  @@map("restaurants")
}

model Menu {
  id           String       @id @default(uuid()) @db.Uuid
  restaurantId String       @unique @map("restaurant_id") @db.Uuid
  status       MenuStatus   @default(DRAFT)
  template     MenuTemplate @default(CLASSIC)
  publishedAt  DateTime?    @map("published_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  restaurant Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories Category[]
  snapshots  MenuPublicSnapshot[]
  dailyDishes DailyDish[]
  formulas         Formula[]

  @@map("menus")
}

model Category {
  id           String   @id @default(uuid()) @db.Uuid
  menuId       String   @map("menu_id") @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  name         String   @db.VarChar(50)
  order        Int
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items      Item[]

  // NOTE: unicité (menuId, lower(btrim(name))) appliquée via index fonctionnel
  // dans supabase/sql/062_categories_custom_names.sql
  @@unique([id, restaurantId])
  @@index([menuId])
  @@index([restaurantId])
  @@map("categories")
}

model Item {
  id           String    @id @default(uuid()) @db.Uuid
  categoryId   String    @map("category_id") @db.Uuid
  restaurantId String    @map("restaurant_id") @db.Uuid
  priceCents   Int       @map("price_cents")
  badge        ItemBadge  @default(NONE)
  allergens    Allergen[] @default([])
  isAvailable  Boolean    @default(true) @map("is_available")
  order        Int
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  // NOTE: FK composite (category_id, restaurant_id) → categories(id, restaurant_id)
  // appliquée au niveau DB via supabase/sql/060_composite_fk_items_category.sql

  @@index([categoryId])
  @@index([restaurantId])
  @@map("items")
}

/// Store unique des textes de menu multilingues (S4) : items, catégories (langues
/// cibles uniquement — la source vit sur categories.name), plats du jour, formules.
/// `entityType`: ITEM|CATEGORY|DAILY_DISH|FORMULA, `field`: name|description,
/// `locale`: codes ISO minuscules — tous contraints par CHECK SQL (076), pas par enum,
/// pour qu'ajouter une langue reste une constante TS + un CHECK.
model Translation {
  id           String   @id @default(uuid()) @db.Uuid
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id") @db.Uuid
  field        String
  locale       String
  value        String
  /// Hash FNV-1a du texte SOURCE au moment de la traduction (fraîcheur calculée).
  /// NULL = ligne legacy/migrée avant backfill ⇒ statut "stale" conservateur.
  sourceTextHash String? @map("source_text_hash")
  restaurantId String   @map("restaurant_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, field, locale])
  @@index([restaurantId])
  @@index([entityType, entityId])
  @@map("translations")
}

model Billing {
  id                   String   @id @default(uuid()) @db.Uuid
  restaurantId         String   @unique @map("restaurant_id") @db.Uuid
  stripeCustomerId     String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("billing")
}

model ProcessedWebhookEvent {
  id            String    @id @default(uuid()) @db.Uuid
  stripeEventId String    @unique @map("stripe_event_id")
  eventType     String    @map("event_type")
  processedAt   DateTime? @map("processed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("processed_webhook_events")
}

model MenuPublicSnapshot {
  id           String    @id @default(uuid()) @db.Uuid
  menuId       String    @map("menu_id") @db.Uuid
  restaurantId String    @unique @map("restaurant_id") @db.Uuid
  slug         String    @unique
  snapshotData Json      @map("snapshot_data")
  publishedAt  DateTime? @map("published_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([menuId])
  @@map("menu_public_snapshots")
}

/// Plat du jour (S3.1). Item exclusif au jour, autonome (sans FK vers Item), avec
/// expiration. La lecture publique filtre par `valid_until > now()` via le port Clock —
/// le snapshot reste immuable mais le rendu est dynamique. Gating : STARTER + PRO.
model DailyDish {
  id            String     @id @default(uuid()) @db.Uuid
  restaurantId  String     @map("restaurant_id") @db.Uuid
  menuId        String     @map("menu_id") @db.Uuid
  priceCents    Int        @map("price_cents")
  badge         ItemBadge  @default(NONE)
  allergens     Allergen[] @default([])
  validUntil    DateTime   @map("valid_until")
  order         Int        @default(0)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId, validUntil])
  @@index([restaurantId])
  @@map("daily_menu_entries")
}

/// Formule de menu (S3.2). Entité autonome (sans FK vers Item) avec composition
/// libre dans la description (multi-ligne, rendu via whitespace-pre-line), prix
/// forfaitaire et expiration obligatoire. Affichée dans la section "Aujourd'hui"
/// du menu public, à côté des plats du jour. Mêmes règles d'expiration et de gating
/// que `DailyDish` : STARTER + PRO uniquement, filtrage `valid_until > now()`
/// à la lecture via le port Clock.
model Formula {
  id            String   @id @default(uuid()) @db.Uuid
  restaurantId  String   @map("restaurant_id") @db.Uuid
  menuId        String   @map("menu_id") @db.Uuid
  priceCents    Int      @map("price_cents")
  validUntil    DateTime @map("valid_until")
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId, validUntil])
  @@index([restaurantId])
  @@map("formulas")
}

model MenuViewEvent {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  slug         String
  locale       Locale
  deviceType   DeviceType @map("device_type")
  source       ViewSource
  createdAt    DateTime   @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@index([createdAt])
  @@map("menu_view_events")
}

model MenuViewDailyStat {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @map("restaurant_id") @db.Uuid
  date         DateTime   @db.Date
  locale       Locale
  deviceType   DeviceType @map("device_type")
  source       ViewSource
  viewCount    Int        @default(0) @map("view_count")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, date, locale, deviceType, source])
  @@index([restaurantId, date])
  @@map("menu_view_daily_stats")
}

/// Landing page tracking events. Anonymous (no restaurant FK), purged after 30 days
/// via pg_cron. RLS: anon/authenticated peuvent INSERT, lecture réservée au
/// service_role. Le champ `eventName` est contraint côté application via le union
/// TS `LandingEventName` (cf. src/domain/analytics/LandingEventNames.ts) + Zod enum
/// au boundary /api/track.
model LandingEvent {
  id         String     @id @default(uuid()) @db.Uuid
  eventName  String     @map("event_name") @db.VarChar(64)
  locale     Locale
  deviceType DeviceType @map("device_type")
  source     String?    @db.VarChar(32)
  metadata   Json?
  userAgent  String?    @map("user_agent") @db.VarChar(500)
  referer    String?    @db.VarChar(500)
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([eventName, createdAt])
  @@index([createdAt])
  @@map("landing_events")
}
